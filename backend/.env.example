DATABASE_URL=sqlite:///./techbiome.db
API_HOST=0.0.0.0
API_PORT=8000

# Worker polling intervals in seconds
MQTT_BRIDGE_INTERVAL=2
ALERT_WORKER_INTERVAL=5

# API authorization mode: permissive (local dev) or enforced (trusted edge only).
SECURITY_MODE=permissive
TRUSTED_PROXY_SECRET=
IDENTITY_EMAIL_HEADER=cf-access-authenticated-user-email
IDENTITY_ROLE_HEADER=x-auth-request-role

# Optional webhook receiver for alert trigger/resolve events.
ALERT_WEBHOOK_URL=
